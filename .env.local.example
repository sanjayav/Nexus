# Copy to .env.local and fill in real values.
#
# ──────────────────────────────────────────────────────────────────────────
#  REQUIRED (production + local API)
# ──────────────────────────────────────────────────────────────────────────

# Postgres connection string — Neon, Supabase, or any Postgres.
# Local: point at a dev branch or Docker postgres.
# Production: set in Vercel project env (Production + Preview).
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# JWT signing secret. MUST be ≥32 chars. Generate with:
#   openssl rand -hex 32
# Production: set in Vercel project env. The API throws on startup if missing.
JWT_SECRET=replace-with-a-32-plus-char-random-string

# CORS allowlist for the API. Comma-separated, fully-qualified origins.
# Local dev origins (http://localhost:5173 etc.) are auto-allowed when
# NODE_ENV !== 'production'; you only need to set this for prod / preview.
ALLOWED_ORIGINS=https://demo.aeiforo.com,https://app.aeiforo.com

# ──────────────────────────────────────────────────────────────────────────
#  OPTIONAL — demo only
# ──────────────────────────────────────────────────────────────────────────

# Shared password for the role-tile one-click login on the Login page.
# If unset, the tiles are hidden and users must type credentials manually.
# Do NOT set this on a customer-facing production deploy.
VITE_DEMO_PASSWORD=demo2026

# ──────────────────────────────────────────────────────────────────────────
#  Frontend dev — pick one of two paths
# ──────────────────────────────────────────────────────────────────────────
# Path A: run API locally. `npm run dev:all` launches Vite (5173) + Vercel
# (3000). Leave VERCEL_API_URL unset — http://localhost:3000 is the default.
#
# Path B: point frontend at a deployed backend. Set VERCEL_API_URL to your
# deployed site. Useful for UI work against live data without running the
# local API.
#
# VERCEL_API_URL=https://your-site.vercel.app
