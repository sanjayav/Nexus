# Copy to .env.local and fill in real values.

# ─── Required ───────────────────────────────────────────────────
DATABASE_URL=                          # Neon Postgres connection string
JWT_SECRET=                            # ≥32 chars; openssl rand -hex 32
ALLOWED_ORIGINS=                       # CSV, e.g. https://app.example.com,https://www.example.com

# ─── Public origin (used in emails, SSO callbacks) ──────────────
APP_BASE_URL=http://localhost:5173

# ─── Setup gate (FIRST DEPLOY) ──────────────────────────────────
SETUP_TOKEN=                           # Random string; used by POST /api/setup once

# ─── Email (Resend) — optional ──────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Aeiforo <notifications@localhost>

# ─── SSO (WorkOS) — optional ────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=                   # Defaults to ${APP_BASE_URL}/api/auth/sso/callback

# ─── AI report drafting (Anthropic Claude) — optional ───────────
ANTHROPIC_API_KEY=

# ─── Error tracking (Sentry) — optional ─────────────────────────
VITE_SENTRY_DSN=

# ─── MFA encryption — optional (falls back to JWT_SECRET) ───────
MFA_ENC_KEY=

# ─── Multi-region (Neon EU/APAC projects) — optional ────────────
DATABASE_URL_EU=
DATABASE_URL_APAC=

# ─── Quick-demo tiles — dev only ────────────────────────────────
VITE_DEMO_PASSWORD=demo2026

# ─── Realtime collaboration (Liveblocks) — optional ─────────────
# Unset = disclosure editor still works; presence avatars / per-cell
# indicators silently disappear. See docs/REALTIME.md to provision.
LIVEBLOCKS_SECRET_KEY=

# ─── Live ERP / SaaS connectors — all optional ──────────────────
# Each provider needs an OAuth app (or API key) registered on the
# provider side. The customer-facing CLIENT_SECRET stays on Nexus —
# end users never see it. See docs/CONNECTORS.md for per-provider
# setup steps (redirect URI to register, scopes to request, etc.).

# SAP S/4HANA Cloud (OAuth 2.0)
SAP_OAUTH_CLIENT_ID=
SAP_OAUTH_CLIENT_SECRET=

# Oracle Fusion ERP Cloud (OAuth 2.0 via IDCS)
ORACLE_OAUTH_CLIENT_ID=
ORACLE_OAUTH_CLIENT_SECRET=

# NetSuite — TBA (Token-Based Authentication). Per-customer creds
# stored on the connection row; no global env vars needed.

# Workday (OAuth 2.0)
WORKDAY_OAUTH_CLIENT_ID=
WORKDAY_OAUTH_CLIENT_SECRET=

# Salesforce (OAuth 2.0 — Connected App)
SALESFORCE_OAUTH_CLIENT_ID=
SALESFORCE_OAUTH_CLIENT_SECRET=

# Snowflake — key-pair JWT. Per-customer keys stored on the connection.

# AWS Cost Explorer — IAM access key per customer; no global env vars.

# Google Cloud Billing (OAuth 2.0)
GCP_OAUTH_CLIENT_ID=
GCP_OAUTH_CLIENT_SECRET=

# Microsoft Azure / M365 (OAuth 2.0 via Microsoft Entra ID)
AZURE_OAUTH_CLIENT_ID=
AZURE_OAUTH_CLIENT_SECRET=
AZURE_TENANT_ID=

# Generic REST — no global env vars; customer supplies endpoint + auth.
