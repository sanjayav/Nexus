# Copy to .env.local and fill in whichever path you use.
#
# ── Path A: run the API locally ───────────────────────────────────────────
# Requires `vercel login` once, then `npm run dev:all` launches both Vite
# (5173) and Vercel (3000). Leave VERCEL_API_URL unset — the default
# http://localhost:3000 is correct.
#
# ── Path B: point frontend at a deployed backend ──────────────────────────
# Set VERCEL_API_URL to your deployed site. Useful for UI work against live
# data without running `vercel dev` locally.
#
# VERCEL_API_URL=https://your-site.vercel.app
