{
  "name": "sustainability-reporting-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx scripts/dev-api.ts",
    "dev:all": "concurrently -n vite,api -c cyan,magenta \"npm:dev\" \"npm:dev:api\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run test && npm run build && npm audit --audit-level=high",
    "check:ci": "npm run test -- --reporter=junit --outputFile=test-results/junit.xml && npm run build && npm audit --audit-level=high",
    "patch-roles": "tsx scripts/patch-roles.ts",
    "seed-org": "tsx scripts/seed-org.ts",
    "seed-client": "tsx scripts/seed-client-demo.ts",
    "seed-all": "tsx scripts/seed-all.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@liveblocks/client": "^3.19.4",
    "@liveblocks/node": "^3.19.4",
    "@liveblocks/react": "^3.19.4",
    "@neondatabase/serverless": "^1.0.2",
    "@react-pdf/renderer": "^3.4.5",
    "@sentry/react": "^10.55.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.87",
    "@tanstack/react-table": "^8.21.3",
    "@types/archiver": "^7.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@workos-inc/node": "^10.0.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.0.0",
    "docx": "^9.7.1",
    "dompurify": "^3.4.7",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "hyperformula": "^3.3.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "jose": "^6.2.2",
    "lucide-react": "^0.294.0",
    "marked": "^18.0.4",
    "otpauth": "^9.5.1",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.16.0",
    "recharts": "^2.10.3",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-router-dom": "^5.3.3",
    "@vercel/node": "^5.8.8",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^4.1.7"
  }
}
